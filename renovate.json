{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "configMigration": true,
  "extends": [
    "config:best-practices",
    "security:minimumReleaseAgeNpm",
    ":automergeAll"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "osvVulnerabilityAlerts": true,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Bun catalog dependencies in root package.json",
      "fileMatch": ["^package\\.json$"],
      "matchStrings": [
        "\"catalog\":\\s*\\{[^}]*?\"(?<depName>[^\"]+)\":\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "npm"
    }
  ]
}
